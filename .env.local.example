# ── API Website V2 ────────────────────────────────────────────────
# URL base da API (sem barra no fim). Dev local usa a :8001 (HTTPS self-signed).
NEXT_PUBLIC_API_BASE=https://localhost:8001

# Tenant (slug do leiloeiro). Resolve qual banco a API usa (header Uloc-Mi).
NEXT_PUBLIC_TENANT=localhost

# Slug do widget de atendimento (crm_widget_config). Usado pelo chat do site.
NEXT_PUBLIC_WIDGET_SLUG=leiloeiroexemplo

# ── WebSocket (tempo real / auditório) ────────────────────────────
# Gateway de realtime (lib comunicator). Em produção:
#   wss://realtime.suporteleiloes.com.br:8446
# Deixe vazio pra desabilitar realtime (a POC cai em polling).
NEXT_PUBLIC_REALTIME_URL=

# ── Dev only ──────────────────────────────────────────────────────
# A API dev usa certificado self-signed. O script `dev` já seta
# NODE_TLS_REJECT_UNAUTHORIZED=0; em produção NUNCA use isso.
